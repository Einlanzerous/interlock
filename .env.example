# Copy to .env and fill in. `docker compose up db` matches these defaults.

# --- Postgres: source of truth, pg-boss queue, and FTS index ---
DATABASE_URL=postgres://interlock:interlock@localhost:5432/interlock
# Host port for the compose `db` service. Override if 5432 is taken on the box.
DB_PORT=5432
# Production only (docker-compose.prod.yml): the DB password baked into the `db` container
# and the internal DATABASE_URL. Change it from the default before exposing the box.
# The dev DATABASE_URL above is separate and unaffected.
POSTGRES_PASSWORD=interlock

# --- Auth: single trusted user (ITLK-13) ---
# The login password, stored as a scrypt hash — the plaintext never lives in this file.
# Generate the line to paste here with:  bun run auth:hash
# (On a box without Bun, see docs/deploy.md for the one-line container form.)
AUTH_PASSWORD_HASH=
# Secret that seals the session cookie. MUST be >=32 chars, and kept stable — changing it
# invalidates every existing session. Generate:  openssl rand -base64 48
SESSION_PASSWORD=
# Set to true once the app is served over HTTPS, so the session cookie is marked TLS-only.
# Leave false for a first boot over plain HTTP (before a reverse proxy is in front of it).
AUTH_COOKIE_SECURE=false

# --- Illinois GA ingest (ITLK-6) ---
# Free LegiScan API key: https://legiscan.com/legiscan
LEGISCAN_API_KEY=
# Open States v3 fallback for IL — documented, not built. See docs/open-states-fallback.md.
OPENSTATES_API_KEY=
LEGISCAN_BASE_URL=https://api.legiscan.com
LEGISCAN_STATE=IL
# Free-tier query cap, tracked durably in `api_budget` (per UTC month).
LEGISCAN_MONTHLY_QUERY_LIMIT=30000
# Bills fetched per poll. The current IL session holds ~12k bills, so an uncapped
# cold start would spend ~40% of the monthly budget in one uninterruptible burst;
# at 500/poll a full backfill lands in about four days.
LEGISCAN_MAX_BILLS_PER_POLL=500
# Self-imposed request cap (LegiScan meters by month, not by second).
LEGISCAN_MAX_RPS=2

# --- Email alerts (ITLK-8) ---
# Leave blank for in-app-only alerts. SMTP connection URL, e.g.
# smtp://user:pass@smtp.example.com:587
SMTP_URL=
ALERT_EMAIL_TO=
# Envelope sender; some relays require one. Defaults to ALERT_EMAIL_TO.
ALERT_EMAIL_FROM=

# --- Poll cadence ---
# Chicago = the Clerk's eLMS (api.chicityclerkelms.chicago.gov, public, no key).
CHI_CLERK_POLL_MINUTES=30
LEGISCAN_POLL_HOURS=4

# --- Chicago eLMS fetcher (ITLK-5) ---
CHI_CLERK_BASE_URL=https://api.chicityclerkelms.chicago.gov
# First-poll window: only matters published in the last N days are backfilled
# (avoids ingesting all ~179k archived matters on a fresh box).
CHI_CLERK_BACKFILL_DAYS=30
# Self-imposed request cap (eLMS publishes no rate limit; brief says <=2/s).
CHI_CLERK_MAX_RPS=2

# --- Sponsor → Official matching (ITLK-7) ---
# pg_trgm similarity at or above which a name match auto-links. Below it, the sponsor
# goes to the review queue for a human instead of being guessed at. Expect to tune this:
# raise it if wrong people are being linked, lower it if the queue fills with obvious
# matches. See docs/sponsor-matching.md.
MATCH_NAME_SIMILARITY_THRESHOLD=0.85

# --- Web ---
WEB_PORT=3000
# Extra hostnames the DEV server will answer to. Vite rejects any Host header it doesn't
# recognize (DNS-rebinding protection), so reaching `nuxi dev --host` from another machine
# by name needs the name listed. This box's own hostname is allowed automatically; add a
# tailnet name, a LAN alias or a reverse proxy here. Comma-separated. Dev only.
WEB_ALLOWED_HOSTS=
