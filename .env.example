# Copy to .env and fill in. `docker compose up db` matches these defaults.

# --- Postgres: source of truth, pg-boss queue, and FTS index ---
DATABASE_URL=postgres://interlock:interlock@localhost:5432/interlock
# Host port for the compose `db` service. Override if 5432 is taken on the box.
DB_PORT=5432

# --- Illinois GA ingest (ITLK-6) ---
# Free LegiScan API key: https://legiscan.com/legiscan
LEGISCAN_API_KEY=
# Open States v3 fallback for IL (optional cross-check / cutover)
OPENSTATES_API_KEY=

# --- Email alerts (ITLK-8) ---
# Leave blank for in-app-only alerts. SMTP connection URL, e.g.
# smtp://user:pass@smtp.example.com:587
SMTP_URL=
ALERT_EMAIL_TO=

# --- Poll cadence ---
LEGISTAR_POLL_MINUTES=30
LEGISCAN_POLL_HOURS=4

# --- Web ---
WEB_PORT=3000
